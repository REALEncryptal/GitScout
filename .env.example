# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gitscout?schema=public"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Auth.js
AUTH_SECRET="" # Generate with: openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# AI Providers (at least one required)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENROUTER_API_KEY="" # Get one at https://openrouter.ai/keys

# Default model (examples: openrouter/openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-haiku-4-5)
# Any openrouter/<model-id> works — see https://openrouter.ai/models
DEFAULT_MODEL="openrouter/openai/gpt-4o-mini"

# Inngest (required in production — get from https://app.inngest.com)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
